<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= title %> | Talk2Me</title>
  <meta name="theme-color" content="#ffffff">
  <link rel="icon" href="<%= basePath %>/public/images/favicon.ico?v=<%= encodeURIComponent(appVersion) %>">
  <link rel="stylesheet" href="<%= basePath %>/public/css/os-v6.css?v=<%= encodeURIComponent(appVersion) %>">
  <link rel="stylesheet" href="<%= basePath %>/public/css/os-v6-alpha3.css?v=<%= encodeURIComponent(appVersion) %>">
</head>
<body class="t2m-os-body">
  <div class="t2m-os-shell" id="talk2me-os">
    <header class="t2m-os-topbar">
      <a class="t2m-os-brand" href="<%= basePath %>/workspace" aria-label="Talk2Me OS home">
        <img src="<%= basePath %>/public/images/talk2me-logo.png" alt="Talk2Me">
        <span><strong>Talk2Me</strong><small>OS v<%= appVersion %></small></span>
      </a>

      <div class="t2m-os-search" role="search">
        <span aria-hidden="true">⌕</span>
        <input id="os-global-search" type="search" autocomplete="off" spellcheck="false"
          placeholder="Search customer, account, phone, email, SIM or MAC..."
          aria-label="Search customer, account, phone, email, SIM or MAC"
          aria-controls="os-search-results" aria-expanded="false">
        <div class="t2m-os-search-results" id="os-search-results" role="listbox" hidden></div>
      </div>

      <div class="t2m-os-top-actions">
        <button class="t2m-os-icon-button" type="button" data-os-app="notifications" aria-label="Notifications">
          <span aria-hidden="true">🔔</span><b class="t2m-os-badge" data-badge="notifications" <%= status.unreadMessageCount ? '' : 'hidden' %>><%= status.unreadMessageCount %></b>
        </button>
        <button class="t2m-os-user-button" type="button" data-os-app="settings" aria-label="Open user settings">
          <span class="t2m-os-avatar"><%= (currentUser.full_name || '?').slice(0, 1).toUpperCase() %></span>
          <span class="t2m-os-user-copy"><strong><%= currentUser.full_name %></strong><small><%= currentUser.role %></small></span>
        </button>
        <form method="post" action="<%= basePath %>/logout"><button class="t2m-os-logout" type="submit">Logout</button></form>
      </div>
    </header>

    <aside class="t2m-os-sidebar" aria-label="Talk2Me applications">
      <div class="t2m-os-sidebar-section">
        <span class="t2m-os-sidebar-label">Work</span>
        <button type="button" data-os-app="queue"><span>▤</span><strong>Queue</strong><b data-badge="queue" <%= status.queueCount ? '' : 'hidden' %>><%= status.queueCount %></b></button>
        <button type="button" data-os-app="tasks"><span>✓</span><strong>Tasks</strong><b data-badge="tasks" <%= status.taskCount ? '' : 'hidden' %>><%= status.taskCount %></b></button>
        <button type="button" data-os-app="messages"><span>●</span><strong>Messages</strong><b data-badge="messages" <%= status.unreadMessageCount ? '' : 'hidden' %>><%= status.unreadMessageCount %></b></button>
        <button type="button" data-os-app="calendar"><span>□</span><strong>Calendar</strong></button>
        <button type="button" data-os-app="notes"><span>✎</span><strong>Notes</strong></button>
        <button type="button" data-os-app="calculator"><span>#</span><strong>Calculator</strong></button>
      </div>

      <div class="t2m-os-sidebar-section">
        <span class="t2m-os-sidebar-label">Information</span>
        <button type="button" data-os-app="reports"><span>▦</span><strong>Reports</strong></button>
        <button type="button" data-os-app="help"><span>?</span><strong>Help</strong></button>
        <button type="button" data-os-app="settings"><span>⚙</span><strong>Settings</strong></button>
      </div>

      <% if (isManagement) { %>
      <div class="t2m-os-sidebar-section">
        <span class="t2m-os-sidebar-label">Management</span>
        <button type="button" data-os-route="<%= basePath %>/command-centre" data-route-title="Command Centre" data-route-icon="◆"><span>◆</span><strong>Command Centre</strong></button>
        <button type="button" data-os-route="<%= basePath %>/approvals" data-route-title="Approvals" data-route-icon="✓"><span>✓</span><strong>Approvals</strong></button>
        <button type="button" data-os-route="<%= basePath %>/upgrade-centre" data-route-title="Upgrade Centre" data-route-icon="↗"><span>↗</span><strong>Upgrades</strong></button>
        <button type="button" data-os-route="<%= basePath %>/backoffice" data-route-title="Administration" data-route-icon="⚙"><span>⚙</span><strong>Administration</strong></button>
      </div>
      <% } %>
    </aside>

    <nav class="t2m-os-launcher" aria-label="Primary systems">
      <button type="button" data-os-launch="customers"><span class="t2m-brand-mark customer">C</span><strong>Customers</strong></button>
      <button type="button" data-os-supplier="vodacom"><span class="t2m-brand-mark vodacom">V</span><strong>Vodacom</strong></button>
      <button type="button" data-os-supplier="mtn"><span class="t2m-brand-mark mtn">MTN</span><strong>MTN</strong></button>
      <button type="button" data-os-supplier="telkom"><span class="t2m-brand-mark telkom">T</span><strong>Telkom</strong></button>
      <button type="button" data-os-supplier="sage"><span class="t2m-brand-mark sage">S</span><strong>Sage</strong></button>
    </nav>

    <main class="t2m-os-workspace" id="os-workspace" aria-label="Talk2Me workspace">
      <section class="t2m-os-desk-widgets" id="os-desk-widgets" aria-label="Today overview">
        <article class="t2m-os-desk-widget" data-widget="work">
          <header><div><span>My desk</span><strong>Today’s Work</strong></div><button type="button" data-widget-collapse aria-label="Collapse Today’s Work">−</button></header>
          <div class="t2m-os-widget-body">
            <button type="button" data-widget-action="overdue" data-os-route="<%= basePath %>/tasks?view=active&due=overdue" data-route-title="Overdue Tasks" data-route-icon="!" aria-label="Open overdue tasks"><span>Overdue tasks</span><strong data-status="overdueTaskCount" data-positive="<%= status.overdueTaskCount > 0 %>"><%= status.overdueTaskCount %></strong></button>
            <button type="button" data-widget-action="due-today" data-os-route="<%= basePath %>/tasks?view=active&due=today" data-route-title="Tasks Due Today" data-route-icon="✓" aria-label="Open tasks due today"><span>Tasks due today</span><strong data-status="dueTodayTaskCount" data-positive="<%= status.dueTodayTaskCount > 0 %>"><%= status.dueTodayTaskCount %></strong></button>
            <button type="button" data-widget-action="followups" data-os-route="<%= basePath %>/work-centre?view=all&follow_up=today" data-route-title="Customer Follow-ups" data-route-icon="↻" aria-label="Open customer follow-ups"><span>Customer follow-ups</span><strong data-status="followUpTodayCount" data-positive="<%= status.followUpTodayCount > 0 %>"><%= status.followUpTodayCount %></strong></button>
            <button type="button" data-widget-action="messages" data-os-app="messages" aria-label="Open unread messages"><span>Unread messages</span><strong data-status="unreadMessageCount" data-positive="<%= status.unreadMessageCount > 0 %>"><%= status.unreadMessageCount %></strong></button>
          </div>
        </article>

        <article class="t2m-os-desk-widget" data-widget="care">
          <header><div><span>Opportunities</span><strong>Client Care Today</strong></div><button type="button" data-widget-collapse aria-label="Collapse Client Care Today">−</button></header>
          <div class="t2m-os-widget-body">
            <button type="button" data-widget-action="birthdays" data-os-route="<%= basePath %>/reports?type=birthdays&date=today" data-route-title="Birthdays Today" data-route-icon="★" aria-label="Open birthdays today"><span>Birthdays</span><strong data-status="birthdaysTodayCount" data-positive="<%= status.birthdaysTodayCount > 0 %>"><%= status.birthdaysTodayCount %></strong></button>
            <button type="button" data-widget-action="upgrades" data-os-route="<%= basePath %>/upgrade-centre?window=7" data-route-title="Upgrade Opportunities" data-route-icon="↗" aria-label="Open upgrade opportunities"><span>Upgrades due</span><strong data-status="upgradesDueCount" data-positive="<%= status.upgradesDueCount > 0 %>"><%= status.upgradesDueCount %></strong></button>
            <button type="button" data-widget-action="callbacks" data-os-route="<%= basePath %>/work-centre?view=all&callback=today" data-route-title="Scheduled Callbacks" data-route-icon="☎" aria-label="Open scheduled callbacks"><span>Scheduled callbacks</span><strong data-status="callbacksTodayCount" data-positive="<%= status.callbacksTodayCount > 0 %>"><%= status.callbacksTodayCount %></strong></button>
            <button type="button" data-widget-action="prospects" data-os-route="<%= basePath %>/backoffice/clients?view=prospects" data-route-title="New Prospects" data-route-icon="+" aria-label="Open new prospects"><span>New prospects</span><strong data-status="newProspectsCount" data-positive="<%= status.newProspectsCount > 0 %>"><%= status.newProspectsCount %></strong></button>
          </div>
        </article>
      </section>
      <div class="t2m-os-window-layer" id="os-window-layer"></div>
    </main>

    <footer class="t2m-os-taskbar" id="os-taskbar" aria-label="Open windows">
      <span class="t2m-os-taskbar-label">Open windows</span>
      <div class="t2m-os-taskbar-items" id="os-taskbar-items"></div>
    </footer>
  </div>

  <div class="t2m-os-toast-region" id="os-toast-region" aria-live="polite" aria-atomic="true"></div>
  <script id="talk2me-os-config" type="application/json"><%- JSON.stringify({
    basePath,
    appVersion,
    user: { id: currentUser.id, name: currentUser.full_name, role: currentUser.role },
    isManagement,
    status
  }).replace(/</g, '\\u003c') %></script>
  <script defer src="<%= basePath %>/public/js/os-v6.js?v=<%= encodeURIComponent(appVersion) %>"></script>
</body>
</html>
