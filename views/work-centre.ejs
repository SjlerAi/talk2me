<section class="page-head"><div><div class="eyebrow">Operational control</div><h1>Work Centre</h1><p>Everything unresolved, overdue, due today or without an owner.</p></div><a class="btn primary" href="<%= basePath %>/queries/new">New Inquiry</a></section>
<nav class="centre-tabs"><a class="<%= view==='overdue'?'active':'' %>" href="?view=overdue">Overdue</a><a class="<%= view==='today'?'active':'' %>" href="?view=today">Due today</a><a class="<%= view==='unassigned'?'active':'' %>" href="?view=unassigned">Unassigned</a><a class="<%= view==='all'?'active':'' %>" href="?view=all">All open</a></nav>
<section class="panel table-card"><h2><%= rows.length %> open item(s)</h2><table class="data-table"><thead><tr><th>Priority</th><th>Client</th><th>Category</th><th>Customer asked</th><th>Action taken</th><th>Responsible</th><th>Follow-up</th><th>Status</th><th></th></tr></thead><tbody><% rows.forEach(i=>{ %><tr><td><span class="badge <%= i.priority %>"><%= i.priority %></span></td><td><strong><%= i.client_name %></strong><small><%= i.cell_number||'' %></small></td><td><%= i.category_name||'Uncategorised' %></td><td><%= i.query_text||'—' %></td><td><%= i.action_taken||'Not captured' %></td><td><%= i.responsible_name %></td><td><%= i.follow_up_at?new Date(i.follow_up_at).toLocaleString('en-ZA'):'Not set' %></td><td><span class="badge <%= i.status %>"><%= i.status.replaceAll('_',' ') %></span></td><td><a class="btn tiny" href="<%= basePath %>/dashboard/inquiries/<%= i.id %>">Open</a></td></tr><% }) %><% if(!rows.length){ %><tr><td colspan="9">No work matches this view.</td></tr><% } %></tbody></table></section>
