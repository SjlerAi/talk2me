<section class="page-head"><div><div class="eyebrow">One reporting workspace</div><h1>Reports</h1><p>Choose a report, apply filters, then print or export from one place.</p></div></section>
<form class="panel centre-filters" method="get"><div><label>Report</label><select name="type"><option value="birthdays" selected>Birthdays</option><option value="upgrades">Upgrades</option><option value="inquiries">Inquiry Activity</option><option value="walkins">Walk-in Contacts</option></select></div><div><label>Window</label><select name="window"><% [['today','Today'],['week','Next 7 days'],['month','This month'],['missing','Missing date']].forEach(x=>{ %><option value="<%= x[0] %>" <%= window===x[0]?'selected':'' %>><%= x[1] %></option><% }) %></select></div><div><label>Search</label><input name="q" value="<%= q %>" placeholder="Cellphone, account, client or email"></div><button class="btn primary">Run</button><button type="button" class="btn" onclick="window.print()">Print</button></form>
<section class="panel table-card"><div class="panel-heading-row"><div><h2>Birthday Report</h2><p class="muted"><%= rows.length %> person(s), grouped to prevent duplicate multi-line birthdays</p></div></div><table class="data-table"><thead><tr><th>Birthday</th><th>Client</th><th>Contact</th><th>Email</th><th>Town</th><th>Lines</th><th>Assigned staff</th><th></th></tr></thead><tbody><% rows.forEach(c=>{ %><tr><td><strong><%= c.birthday?new Date(c.birthday).toLocaleDateString('en-ZA',{day:'2-digit',month:'short'}):'Missing' %></strong></td><td><%= c.client_name %><% if(c.main_contact_name){ %><small>Main contact: <%= c.main_contact_name %></small><% } %></td><td><%= c.cell_number||'—' %></td><td><%= c.email||'—' %></td><td><%= c.city_town&&c.city_town!=='null'?c.city_town:'—' %></td><td><%= c.line_count %></td><td><%= c.assigned_name %></td><td><a class="btn tiny" href="<%= basePath %>/customers/<%= c.id %>/360">Open</a></td></tr><% }) %><% if(!rows.length){ %><tr><td colspan="8">No birthdays match this report.</td></tr><% } %></tbody></table></section>
<script>document.querySelector('select[name="type"]').addEventListener('change',e=>{const v=e.target.value;if(v==='upgrades')location='<%= basePath %>/upgrade-centre';else if(v==='inquiries')location='<%= basePath %>/backoffice/inquiries';else if(v==='walkins')location='<%= basePath %>/backoffice/reports/new-contacts'})</script>
