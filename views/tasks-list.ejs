<% const panelSuffix = panelMode ? (view ? '&panel=1' : '?panel=1') : ''; %>
<% const taskUrl = id => `${basePath}/tasks/${id}${panelMode?'?panel=1':''}`; %>
<section class="hero-row"><div><h1><%= title %></h1><p>Active work stays here until it is completed. Completed items remain safely searchable in the archive.</p></div><div class="hero-actions"><a class="btn primary" href="<%= basePath %>/tasks/new<%= panelMode?'?panel=1':'' %>">Send Message / Task</a></div></section>
<nav class="centre-tabs task-tabs" aria-label="Message and task views">
  <a class="<%= view==='active'?'active':'' %>" href="<%= basePath %>/tasks<%= panelMode?'?panel=1':'' %>">My Active</a>
  <a class="<%= view==='sent'?'active':'' %>" href="<%= basePath %>/tasks?view=sent<%= panelMode?'&panel=1':'' %>">Sent by Me</a>
  <a class="<%= view==='archive'?'active':'' %>" href="<%= basePath %>/tasks?view=archive<%= panelMode?'&panel=1':'' %>">Completed Archive</a>
  <% if(isOwner){ %><a class="<%= view==='all'?'active':'' %>" href="<%= basePath %>/tasks?view=all<%= panelMode?'&panel=1':'' %>">All Staff Active</a><% } %>
</nav>
<% if(archiveView){ %><section class="panel"><form class="task-archive-filters" method="get"><input type="hidden" name="view" value="archive"><% if(panelMode){ %><input type="hidden" name="panel" value="1"><% } %><label>Search<input name="q" value="<%= filters.q %>" placeholder="Title, message, sender, recipient or client"></label><label>From<input type="date" name="from" value="<%= filters.from %>"></label><label>To<input type="date" name="to" value="<%= filters.to %>"></label><% if(isOwner){ %><label>Staff<select name="staff_id"><option value="">All staff</option><% staff.forEach(s=>{ %><option value="<%= s.id %>" <%= Number(filters.staffFilter)===Number(s.id)?'selected':'' %>><%= s.full_name %></option><% }) %></select></label><% } %><button class="btn primary" type="submit">Search Archive</button></form></section><% } %>
<section class="panel table-card"><table class="data-table"><thead><tr><th>Priority</th><th>Message / Task</th><th>From</th><th>Assigned to</th><th>Due / Completed</th><th>Status</th></tr></thead><tbody>
<% tasks.forEach(t=>{ %><tr class="click-row <%= t.priority==='urgent'?'urgent-row':'' %>" data-task-url="<%= taskUrl(t.id) %>" tabindex="0" role="link"><td><span class="badge <%= t.priority %>"><%= t.priority %></span></td><td><strong><%= t.title %></strong><small><%= t.type %><%= t.related_client_name?' · '+t.related_client_name:'' %><%= t.related_fixed_name?' · Fixed: '+t.related_fixed_name+' ('+t.related_fixed_account+')':'' %></small></td><td><%= t.created_by_name %></td><td><%= t.assigned_name %></td><td><%= archiveView?(t.completed_at?new Date(t.completed_at).toLocaleString('en-ZA'):'Cancelled'):(t.due_at?new Date(t.due_at).toLocaleString('en-ZA'):'No due date') %></td><td><span class="badge <%= t.status %>"><%= t.status.replaceAll('_',' ') %></span></td></tr><% }) %>
<% if(!tasks.length){ %><tr><td colspan="6"><%= archiveView?'No completed messages or tasks match these filters.':'Nothing active here. All caught up.' %></td></tr><% } %></tbody></table></section>
<script>
(()=>{
  document.querySelectorAll('[data-task-url]').forEach(row=>{
    const open=()=>{window.location.href=row.dataset.taskUrl};
    row.addEventListener('click',open);
    row.addEventListener('keydown',event=>{if(event.key==='Enter'||event.key===' '){event.preventDefault();open()}});
  });
})();
</script>
