<section class="command-hero"><div><div class="eyebrow">Owner & management control</div><h1>Shop Command Centre</h1><p>The complete shop picture. Open any item as a work panel without leaving this screen.</p></div><div class="hero-actions"><a class="btn primary" href="<%= basePath %>/tasks?view=all" data-command-panel>All Messages & Tasks<% if(unreadTaskCount){ %> (<%= unreadTaskCount %>)<% } %></a><a class="btn" href="<%= basePath %>/workspace">My Workspace</a></div></section>
<section class="global-search panel"><label for="command-search">Find any mobile or fixed customer</label><div class="command-search-row"><input id="command-search" placeholder="Cellphone, account, customer, email, solution, order, SIM or MAC" autocomplete="off"><button class="btn primary" id="command-search-button">Search</button></div><div id="command-results" class="command-results"></div></section>
<section class="command-stats">
<a href="<%= basePath %>/work-centre?view=all"><span>Open inquiries</span><strong><%= stats.open_inquiries||0 %></strong></a>
<a class="danger" href="<%= basePath %>/work-centre?view=overdue"><span>Overdue inquiries</span><strong><%= stats.overdue_inquiries||0 %></strong></a>
<a class="warning" href="<%= basePath %>/work-centre?view=today"><span>Due today</span><strong><%= stats.due_today||0 %></strong></a>
<a href="<%= basePath %>/tasks?view=all"><span>Open tasks</span><strong><%= stats.open_tasks||0 %></strong></a>
<a class="danger" href="<%= basePath %>/tasks?view=all"><span>Overdue tasks</span><strong><%= stats.overdue_tasks||0 %></strong></a>
<a class="opportunity" href="<%= basePath %>/upgrade-centre?window=today"><span>Upgrades today</span><strong><%= stats.upgrades_today||0 %></strong></a>
<a class="warning" href="<%= basePath %>/upgrade-centre?window=overdue"><span>Overdue upgrades</span><strong><%= stats.overdue_upgrades||0 %></strong></a>
<a href="#birthdays"><span>Birthdays today</span><strong><%= stats.birthdays_today||0 %></strong></a>
<a href="<%= basePath %>/backoffice/reports/new-contacts"><span>Walk-ins today</span><strong><%= stats.walkins_today||0 %></strong></a>
<a href="<%= basePath %>/backoffice/clients?view=unassigned"><span>Unassigned clients</span><strong><%= stats.unassigned_clients||0 %></strong></a>
<a class="opportunity" href="<%= basePath %>/fixed/services?status=active"><span>Active fixed services</span><strong><%= stats.active_fixed_services||0 %></strong></a>
<a class="warning" href="<%= basePath %>/fixed/accounts"><span>Unassigned fixed accounts</span><strong><%= stats.unassigned_fixed_accounts||0 %></strong></a>
<a class="warning" href="<%= basePath %>/approvals"><span>Claims awaiting approval</span><strong><%= stats.pending_claims||0 %></strong></a>
</section>
<section class="command-grid"><div class="panel"><div class="panel-heading-row command-panel-head"><div><h2>Needs Attention</h2><p class="muted">Outstanding and overdue shop work</p></div><a class="btn primary panel-action" href="<%= basePath %>/work-centre?view=all">View All Work</a></div><div class="attention-list"><% if(!attention.length){ %><div class="empty-state">Nothing urgent requires attention.</div><% } %><% attention.forEach(x=>{ %><a href="<%= x.item_type==='task' ? basePath+'/tasks/'+x.item_id : basePath+'/dashboard/inquiries/'+x.item_id %>"><span class="attention-dot <%= x.reason.toLowerCase().includes('overdue')?'danger':'warning' %>"></span><div><strong><%= x.client_name %></strong><small><%= x.cell_number||'' %> · <%= x.reason %> · <%= x.owner_name %></small></div><span class="badge <%= x.priority %>"><%= x.priority %></span></a><% }) %></div></div>
<div class="panel"><div class="panel-heading-row command-panel-head"><div><h2>Upgrade Opportunities</h2><p class="muted">Overdue through next 7 days</p></div><a class="btn primary panel-action" href="<%= basePath %>/upgrade-centre">Open Upgrade Centre</a></div><% upgrades.forEach(c=>{ %><a class="mini-client" href="<%= basePath %>/customers/<%= c.id %>/360"><div><strong><%= c.client_name %></strong><small><%= c.cell_number %> · <%= c.handset||'No handset' %></small></div><span class="badge <%= c.days_until<0?'danger':c.days_until===0?'warn':'ok' %>"><%= c.days_until<0 ? Math.abs(c.days_until)+'d overdue' : c.days_until===0?'Today':c.days_until+'d' %></span></a><% }) %><% if(!upgrades.length){ %><div class="empty-state">No upgrade opportunities in this window.</div><% } %></div></section>
<section class="panel" id="birthdays"><div class="panel-heading-row command-panel-head"><div><h2>Birthdays Today</h2><p class="muted">Grouped by person so multi-line clients appear once</p></div><a class="btn primary panel-action" href="<%= basePath %>/reports?type=birthdays&window=today">Open Birthday Report</a></div><div class="birthday-grid"><% birthdays.forEach(c=>{ %><a href="<%= basePath %>/customers/<%= c.id %>/360"><strong><%= c.client_name %></strong><small><%= c.cell_number||'No contact' %> · <%= c.email||'No email' %> · <%= c.line_count %> line(s)</small></a><% }) %><% if(!birthdays.length){ %><div class="empty-state">No birthdays today.</div><% } %></div></section>
<script>(()=>{const q=document.getElementById('command-search'),r=document.getElementById('command-results'),b=document.getElementById('command-search-button');let timer;async function search(){const v=q.value.trim();if(v.length<2){r.innerHTML='';return}const rows=await fetch('<%= basePath %>/search/all?q='+encodeURIComponent(v)).then(x=>x.json());r.innerHTML=rows.length?rows.map(c=>`<a href="${c.url}"><strong><span class="search-type ${c.record_type}">${c.record_type==='fixed'?'FIXED':'MOBILE'}</span> ${c.client_name||'Unnamed'}</strong><small>${c.cell_number||c.branch_name||''} · ${c.account_number||'No account'} · ${c.solution_id||c.handset||'No service detail'}</small></a>`).join(''):`<div class="universal-no-result"><strong>No customer found</strong><small>${v}</small><a class="btn primary" href="<%= basePath %>/queries/new?new_phone=${encodeURIComponent(v)}">+ Add New Customer & Continue Inquiry</a></div>`}q.addEventListener('input',()=>{clearTimeout(timer);timer=setTimeout(search,220)});b.addEventListener('click',search);q.addEventListener('keydown',e=>{if(e.key==='Enter'){e.preventDefault();search()}})})();</script>
