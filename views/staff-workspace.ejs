<section class="workstation-hero">
  <div>
    <div class="eyebrow">Talk2Me Workstation</div>
    <h1>Your day starts here</h1>
    <p>Find the customer, open the right system, complete the work and return to this screen.</p>
  </div>
  <div class="workstation-status">
    <span>Signed in as</span>
    <strong><%= currentUser.full_name %></strong>
    <small><%= currentUser.role %> · live operational workspace</small>
  </div>
</section>

<section class="workstation-search-card">
  <div>
    <span class="workstation-kicker">Start with the customer</span>
    <h2>Who are we helping?</h2>
    <p>Search by cellphone, account, customer, email, SIM, IMEI, MAC or fixed-service detail.</p>
  </div>
  <button type="button" class="btn primary workstation-search-button" onclick="document.getElementById('universal-client-search').focus()">Search customer</button>
</section>

<section class="supplier-launchpad" aria-labelledby="supplier-launchpad-title">
  <div class="section-title-row">
    <div>
      <span class="workstation-kicker">External systems</span>
      <h2 id="supplier-launchpad-title">Supplier launchpad</h2>
      <p>Each supplier opens in its own window. Close or minimise it to return to Talk2Me.</p>
    </div>
  </div>
  <div class="supplier-grid">
    <% [1,2,3].forEach(number=>{ %>
    <article class="supplier-card" data-supplier-card="<%= number %>">
      <div class="supplier-card-top"><span class="supplier-number">0<%= number %></span><button type="button" class="supplier-configure" data-supplier-configure="<%= number %>">Configure</button></div>
      <div class="supplier-icon">↗</div>
      <h3 data-supplier-name="<%= number %>">Supplier system <%= number %></h3>
      <p data-supplier-state="<%= number %>">Add the supplier name and secure portal URL on this workstation.</p>
      <button type="button" class="supplier-open" data-supplier-open="<%= number %>">Set up link</button>
    </article>
    <% }) %>
  </div>
</section>

<section class="workspace-actions workstation-quick-actions">
  <a class="primary" href="<%= basePath %>/queries/new" data-command-panel><b>＋</b><span>New inquiry<small>Capture a call or walk-in</small></span></a>
  <a href="<%= basePath %>/tasks/new" data-command-panel><b>→</b><span>Send message<small>To any staff member</small></span></a>
  <a href="<%= basePath %>/tasks" data-command-panel><b>✓</b><span>My active work<small><%= stats.tasks %> open item(s)</small></span></a>
  <a href="<%= basePath %>/work-centre?view=all" data-command-panel><b>☷</b><span>Full work queue<small>All open and overdue work</small></span></a>
</section>

<section class="workspace-board workstation-board">
  <div class="workspace-column" id="my-inquiries">
    <div class="workspace-column-head"><div><span class="signal red"></span><h2>My Work Queue</h2></div><a href="<%= basePath %>/work-centre?view=all" data-command-panel>Open full queue</a></div>
    <p class="column-intro">Customer work and follow-ups in priority order.</p>
    <div class="work-card-list">
      <% work.slice(0,12).forEach(i=>{const late=i.follow_up_at&&new Date(i.follow_up_at)<new Date();%>
      <a class="work-card <%= late?'late':'' %>" href="<%= basePath %>/dashboard/inquiries/<%= i.id %>" data-command-panel>
        <div><span class="work-type"><%= i.category_name||'Inquiry' %></span><strong><%= i.client_name %></strong><p><%= i.query_text||'No detail captured' %></p><small><%= i.follow_up_at?(late?'Overdue · ':'Due · ')+new Date(i.follow_up_at).toLocaleString('en-ZA'):'No follow-up date' %></small></div><b>Open →</b>
      </a>
      <% }) %>
      <% if(!work.length){%><div class="workspace-clear">✓ Your inquiry queue is clear.</div><%}%>
    </div>
  </div>
  <div class="workspace-column" id="my-tasks">
    <div class="workspace-column-head"><div><span class="signal amber"></span><h2>Messages & Tasks</h2></div><a href="<%= basePath %>/tasks" data-command-panel>Open all</a></div>
    <p class="column-intro">Items stay here until completed or cancelled.</p>
    <div class="work-card-list">
      <% tasks.slice(0,12).forEach(t=>{const late=t.due_at&&new Date(t.due_at)<new Date();%>
      <a class="work-card <%= late?'late':'' %>" href="<%= basePath %>/tasks/<%= t.id %>" data-command-panel>
        <div><span class="work-type"><%= t.type %> · <%= t.priority %></span><strong><%= t.title %></strong><p><%= t.message %></p><small><%= t.due_at?(late?'Overdue · ':'Due · ')+new Date(t.due_at).toLocaleString('en-ZA'):'No due date' %></small></div><b>Open →</b>
      </a>
      <% }) %>
      <% if(!tasks.length){%><div class="workspace-clear">✓ No active messages or tasks.</div><%}%>
    </div>
  </div>
</section>

<section class="active-customer-placeholder">
  <div class="active-customer-icon">◎</div>
  <div><span class="workstation-kicker">Active customer</span><h2>No customer selected</h2><p>Use the search bar above. The selected customer will open in the Talk2Me work panel without losing this workstation.</p></div>
  <button type="button" class="btn" onclick="document.getElementById('universal-client-search').focus()">Find customer</button>
</section>

<section class="workspace-board secondary-board" id="opportunities">
  <div class="workspace-column"><div class="workspace-column-head"><div><span class="signal green"></span><h2>Upgrade Opportunities</h2></div><span><%= upgrades.length %> clients</span></div><div class="compact-list"><% upgrades.slice(0,10).forEach(c=>{%><a href="<%= basePath %>/customers/<%= c.id %>/360" data-command-panel><div><strong><%= c.client_name %></strong><span><%= c.cell_number %> · <%= c.account_number||'No account' %></span></div><b><%= c.next_upgrade_date?new Date(c.next_upgrade_date).toLocaleDateString('en-ZA'):'Unknown' %></b></a><%})%><%if(!upgrades.length){%><div class="workspace-clear">No upgrade opportunities.</div><%}%></div></div>
  <div class="workspace-column" id="client-care"><div class="workspace-column-head"><div><span class="signal blue"></span><h2>Client Care Today</h2></div><span><%= birthdays.length %> birthdays</span></div><div class="compact-list"><% birthdays.forEach(c=>{%><a href="<%= basePath %>/customers/<%= c.id %>/360" data-command-panel><div><strong><%= c.client_name %></strong><span><%= c.cell_number||'No number' %> · <%= c.email||'No email' %></span></div><b>Open →</b></a><%})%><%if(!birthdays.length){%><div class="workspace-clear">No birthdays today.</div><%}%></div></div>
</section>

<section class="workspace-summary workstation-summary"><div class="workspace-summary-title"><span>Workstation totals</span><small>Your live operational position</small></div><div class="workspace-metrics">
  <a href="#my-inquiries"><span>Open inquiries</span><strong><%= stats.open %></strong><small>assigned to me</small></a><a class="urgent" href="#my-inquiries"><span>Overdue inquiries</span><strong><%= stats.overdue %></strong><small>needs attention</small></a><a href="#my-tasks"><span>Messages & tasks</span><strong><%= stats.tasks %></strong><small>active queue</small></a><a class="urgent" href="#my-tasks"><span>Overdue tasks</span><strong><%= stats.taskOverdue %></strong><small>act now</small></a><a class="positive" href="#opportunities"><span>Upgrade opportunities</span><strong><%= stats.upgrades %></strong><small>next 7 days</small></a><a href="#client-care"><span>Birthdays today</span><strong><%= stats.birthdays %></strong><small>my customers</small></a>
</div></section>

<script>
(()=>{
  const key='talk2me-supplier-launchers-v1';
  const defaults=[null,{name:'Supplier system 1',url:''},{name:'Supplier system 2',url:''},{name:'Supplier system 3',url:''}];
  let suppliers;
  try{suppliers=JSON.parse(localStorage.getItem(key))||defaults}catch(e){suppliers=defaults}
  function save(){localStorage.setItem(key,JSON.stringify(suppliers))}
  function paint(number){
    const item=suppliers[number]||defaults[number], name=document.querySelector(`[data-supplier-name="${number}"]`), state=document.querySelector(`[data-supplier-state="${number}"]`), open=document.querySelector(`[data-supplier-open="${number}"]`);
    name.textContent=item.name||`Supplier system ${number}`;
    state.textContent=item.url?'Ready to open in a separate secure browser window.':'Add the supplier name and secure portal URL on this workstation.';
    open.textContent=item.url?'Open portal':'Set up link';
    open.classList.toggle('ready',Boolean(item.url));
  }
  function configure(number){
    const current=suppliers[number]||defaults[number];
    const name=prompt('Supplier name',current.name||`Supplier system ${number}`);if(name===null)return;
    const url=prompt('Secure supplier portal URL (https://...)',current.url||'https://');if(url===null)return;
    if(url&&!/^https:\/\//i.test(url)){alert('For safety, supplier links must start with https://');return}
    suppliers[number]={name:name.trim()||`Supplier system ${number}`,url:url.trim()};save();paint(number);
  }
  document.querySelectorAll('[data-supplier-configure]').forEach(button=>button.addEventListener('click',()=>configure(Number(button.dataset.supplierConfigure))));
  document.querySelectorAll('[data-supplier-open]').forEach(button=>button.addEventListener('click',()=>{const number=Number(button.dataset.supplierOpen),item=suppliers[number]||defaults[number];if(!item.url){configure(number);return}window.open(item.url,`talk2me-supplier-${number}`,'noopener,noreferrer')}));
  [1,2,3].forEach(paint);
  addEventListener('workspace:refresh',()=>location.reload());
})();
</script>