<section class="os6-shell" aria-label="Talk2Me OS workspace">
  <nav class="os6-launchbar" aria-label="Primary launchers">
    <button type="button" class="os6-launch os6-launch-customer" onclick="document.getElementById('universal-client-search').focus()"><span>⌕</span><strong>Customer</strong></button>
    <% [1,2,3].forEach(number=>{ %>
      <button type="button" class="os6-launch" data-supplier-open="<%= number %>"><span>↗</span><strong data-supplier-name="<%= number %>">Supplier <%= number %></strong></button>
    <% }) %>
  </nav>

  <main class="os6-desktop" id="os6-desktop">
    <div class="os6-empty-state" id="os6-empty-state">
      <div class="os6-mark">T</div>
      <strong>Talk2Me</strong>
      <span>Select a launcher or search for a customer.</span>
    </div>

    <section class="os6-window os6-window-active" data-os6-window="queue" hidden>
      <header><