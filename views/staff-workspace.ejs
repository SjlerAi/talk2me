<section class="workspace-actions workspace-actions-first"><a class="primary" href="<%= basePath %>/queries/new" data-command-panel><b>＋</b><span>New inquiry<small>Capture a call or walk-in</small></span></a><button onclick="document.getElementById('universal-client-search').focus()"><b>⌕</b><span>Find customer<small>Mobile and fixed</small></span></button><a href="<%= basePath %>/tasks/new" data-command-panel><b>→</b><span>Send message<small>To any staff member</small></span></a><a href="<%= basePath %>/tasks" data-command-panel><b>✓</b><span>My active work<small><%= stats.tasks %> open item(s)</small></span></a></section>
<section class="workspace-board">
 <div class="workspace-column" id="my-inquiries"><div class="workspace-column-head"><div><span class="signal red"></span><h2>Do Next</h2></div><a href="<%= basePath %>/work-centre?view=all" data-command-panel>View queue</a></div><p class="column-intro">Customer work and follow-ups in priority order.</p><div class="work-card-list"><% work.slice(0,12).forEach(i=>{const late=i.follow_up_at&&new Date(i.follow_up_at)<new Date();%><a class="work-card <%= late?'late':'' %>" href="<%= basePath %>/dashboard/inquiries/<%= i.id %>" data-command-panel><div><span class="work-type"><%= i.category_name||'Inquiry' %></span><strong><%= i.client_name %></strong><p><%= i.query_text||'No detail captured' %></p><small><%= i.follow_up_at?(late?'Overdue · ':'Due · ')+new Date(i.follow_up_at).toLocaleString('en-ZA'):'No follow-up date' %></small></div><b>Open →</b></a><% }) %><% if(!work.length){%><div class="workspace-clear">✓ Your inquiry queue is clear.</div><%}%></div></div>
 <div class="workspace-column" id="my-tasks"><div class="workspace-column-head"><div><span class="signal amber"></span><h2>Messages & Tasks</h2></div><a href="<%= basePath %>/tasks" data-command-panel>Open all</a></div><p class="column-intro">Items stay here until completed or cancelled.</p><div class="work-card-list"><% tasks.slice(0,12).forEach(t=>{const late=t.due_at&&new Date(t.due_at)<new Date();%><a class="work-card <%= late?'late':'' %>" href="<%= basePath %>/tasks/<%= t.id %>" data-command-panel><div><span class="work-type"><%= t.type %> · <%= t.priority %></span><strong><%= t.title %></strong><p><%= t.message %></p><small><%= t.due_at?(late?'Overdue · ':'Due · ')+new Date(t.due_at).toLocaleString('en-ZA'):'No due date' %></small></div><b>Open →</b></a><% }) %><% if(!tasks.length){%><div class="workspace-clear">✓ No active messages or tasks.</div><%}%></div></div>
</section>
<section class="workspace-board secondary-board" id="opportunities"><div class="workspace-column"><div class="workspace-column-head"><div><span class="signal green"></span><h2>Upgrade Opportunities</h2></div><span><%= upgrades.length %> clients</span></div><div class="compact-list"><% upgrades.slice(0,10).forEach(c=>{%><a href="<%= basePath %>/customers/<%= c.id %>/360" data-command-panel><div><strong><%= c.client_name %></strong><span><%= c.cell_number %> · <%= c.account_number||'No account' %></span></div><b><%= c.next_upgrade_date?new Date(c.next_upgrade_date).toLocaleDateString('en-ZA'):'Unknown' %></b></a><%})%><%if(!upgrades.length){%><div class="workspace-clear">No upgrade opportunities.</div><%}%></div></div><div class="workspace-column" id="client-care"><div class="workspace-column-head"><div><span class="signal blue"></span><h2>Client Care Today</h2></div><span><%= birthdays.length %> birthdays</span></div><div class="compact-list"><% birthdays.forEach(c=>{%><a href="<%= basePath %>/customers/<%= c.id %>/360" data-command-panel><div><strong><%= c.client_name %></strong><span><%= c.cell_number||'No number' %> · <%= c.email||'No email' %></span></div><b>Open →</b></a><%})%><%if(!birthdays.length){%><div class="workspace-clear">No birthdays today.</div><%}%></div></div></section>
<section class="workspace-summary"><div class="workspace-summary-title"><span>Workspace totals</span><small>A quick summary after your operational queues</small></div><div class="workspace-metrics">
 <a href="#my-inquiries"><span>Open inquiries</span><strong><%= stats.open %></strong><small>assigned to me</small></a><a class="urgent" href="#my-inquiries"><span>Overdue inquiries</span><strong><%= stats.overdue %></strong><small>needs attention</small></a><a href="#my-tasks"><span>Messages & tasks</span><strong><%= stats.tasks %></strong><small>active queue</small></a><a class="urgent" href="#my-tasks"><span>Overdue tasks</span><strong><%= stats.taskOverdue %></strong><small>act now</small></a><a class="positive" href="#opportunities"><span>Upgrade opportunities</span><strong><%= stats.upgrades %></strong><small>next 7 days</small></a><a href="#client-care"><span>Birthdays today</span><strong><%= stats.birthdays %></strong><small>my customers</small></a>
</div></section>
<script>addEventListener('workspace:refresh',()=>location.reload())</script>
