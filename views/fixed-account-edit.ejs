<section class="page-head"><div><a href="<%= basePath %>/fixed/accounts/<%= account.id %>">← Fixed Customer 360</a><h1>Edit Fixed Account</h1><p>Contact, authority, assignment and mobile linking are managed here.</p></div></section>
<form class="panel form-grid" method="post" action="<%= basePath %>/fixed/accounts/<%= account.id %>"><label>Customer name<input name="customer_name" required value="<%= account.customer_name %>"></label><label>Account number<input value="<%= account.account_number %>" disabled></label><label>Contact person<input name="contact_name" value="<%= account.contact_name||'' %>"></label><label>Contact telephone<input name="contact_number" value="<%= account.contact_number||'' %>"></label><label>Email<input name="email" type="email" value="<%= account.email||'' %>"></label><label>Assigned staff<select name="assigned_staff_id"><option value="">Unassigned</option><% staff.forEach(s=>{ %><option value="<%= s.id %>" <%= Number(account.assigned_staff_id)===s.id?'selected':'' %>><%= s.full_name %> (<%= s.role %>)</option><% }) %></select></label><label>Authorised contact<input name="authorised_contact_name" value="<%= account.authorised_contact_name||'' %>"></label><label>Authorised contact number<input name="authorised_contact_number" value="<%= account.authorised_contact_number||'' %>"></label><label>Authority status<select name="authority_status"><% ['unknown','confirmed','not_authorised'].forEach(x=>{ %><option value="<%= x %>" <%= account.authority_status===x?'selected':'' %>><%= x %></option><% }) %></select></label><label>Account status<select name="account_status"><% ['active','inactive','cancelled','unknown'].forEach(x=>{ %><option value="<%= x %>" <%= account.account_status===x?'selected':'' %>><%= x %></option><% }) %></select></label><label class="full">Linked mobile account<select name="linked_mobile_account_number"><option value="">No mobile account link</option><% mobileAccounts.forEach(m=>{ %><option value="<%= m.account_number %>" <%= account.linked_mobile_account_number===m.account_number?'selected':'' %>><%= m.client_name %> — <%= m.account_number %> (<%= m.line_count %> lines)</option><% }) %></select><small>Only select a mobile account after confirming it is the same customer.</small></label><label class="full">Notes<textarea name="notes"><%= account.notes||'' %></textarea></label><button class="btn primary" type="submit">Save Fixed Account</button></form>
