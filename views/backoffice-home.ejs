<section class="page-head">
  <div><h1>Administration</h1><p>Maintain staff, customer records and detailed reports. Daily operations start in the Command Centre.</p></div><a class="btn primary" href="<%= basePath %>/command-centre">Open Command Centre</a>
</section>
<div class="module-grid">
  <a class="module-card" href="<%= basePath %>/backoffice/staff"><span class="module-icon">👥</span><h2>Staff</h2><p>Users, roles, profiles, photos and ID documents.</p></a>
  <a class="module-card" href="<%= basePath %>/backoffice/attendance"><span class="module-icon">🕒</span><h2>Login & Attendance</h2><p>See active sessions, login and logout times, activity and daily hours.</p></a>
  <a class="module-card" href="<%= basePath %>/backoffice/clients"><span class="module-icon">🧾</span><h2>Client Administration</h2><p>Maintain contact details, ownership, authority, status and line information.</p></a>
  <a class="module-card" href="<%= basePath %>/tasks?view=all"><span class="module-icon">📣</span><h2>Messages & Tasks</h2><p>Send staff notifications, assign work, track progress and confirm completion.</p></a>
  <a class="module-card" href="<%= basePath %>/backoffice/inquiries"><span class="module-icon">🗂️</span><h2>Inquiries</h2><p>Category reports, status tracking, follow-ups and staff performance.</p></a>
  <a class="module-card" href="<%= basePath %>/upgrade-centre"><span class="module-icon">📈</span><h2>Upgrade Centre</h2><p>Historical and upcoming upgrade opportunities across every client line.</p></a>
  <a class="module-card" href="<%= basePath %>/work-centre"><span class="module-icon">⏰</span><h2>Work Centre</h2><p>Open, overdue, due-today and unassigned customer work.</p></a>
  <a class="module-card" href="<%= basePath %>/backoffice/reports/new-contacts"><span class="module-icon">📊</span><h2>Reports</h2><p>Walk-ins, staff activity and birthday correction history.</p></a>
  <% if(['owner','admin'].includes(currentUser.role)){ %><a class="module-card" href="<%= basePath %>/backoffice/os-launchers"><span class="module-icon">⚙️</span><h2>Workstation Launchers</h2><p>Set the four top-window names, icons and secure external-system links for all staff.</p></a><% } %>
</div>
