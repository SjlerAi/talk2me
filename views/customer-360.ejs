<section class="customer-head"><div><a href="<%= basePath %>/command-centre">← Command Centre</a><div class="eyebrow">Customer 360</div><h1><%= client.client_name %></h1><p>Unique account <strong><%= accountRecord?.account_number||client.account_number||'not captured' %></strong> · <%= lines.length %> line(s) · Assigned to <%= accountRecord?.assigned_staff_name||assignment?.full_name||'Unassigned' %></p></div><div class="hero-actions account-action-row"><a class="btn primary" href="<%= basePath %>/queries/new?client_id=<%= client.id %>">New Inquiry</a><% if(client.account_number){ %><a class="btn opportunity" href="<%= ['owner','manager'].includes(currentUser.role) ? basePath+'/backoffice/clients/new?account_number='+encodeURIComponent(client.account_number)+'&client_name='+encodeURIComponent(client.client_name)+'&email='+encodeURIComponent(client.email||'') : basePath+'/customers/'+client.id+'/request-mobile-line' %>">Add Mobile Line</a><a class="btn opportunity" href="<%= ['owner','manager'].includes(currentUser.role) ? basePath+'/fixed/services/new?account_number='+encodeURIComponent(client.account_number) : basePath+'/fixed/services/request-new?account_number='+encodeURIComponent(client.account_number) %>">Add Fixed Service</a><% } %><% if(currentUser.role==='staff'&&accountRecord&&!accountRecord.assigned_staff_id&&!pendingClaim){ %><form method="post" action="<%= basePath %>/customers/<%= client.id %>/request-claim" class="claim-inline"><button class="btn warning" type="submit">Request Claim</button></form><% } %><% if(pendingClaim){ %><span class="badge warn">Claim pending: <%= pendingClaim.requested_by_name %></span><% } %><% if(['owner','manager'].includes(currentUser.role)){ %><a class="btn" href="<%= basePath %>/backoffice/clients/<%= client.id %>/edit">Edit Line</a><% } else { %><a class="btn" href="<%= basePath %>/customers/<%= client.id %>/propose-change">Request Line Change</a><% } %></div></section>
<section class="answer-grid"><div><span>Next upgrade</span><strong><%= client.next_upgrade_date?new Date(client.next_upgrade_date).toLocaleDateString('en-ZA',{dateStyle:'medium'}):'Unknown' %></strong><small><%= client.previous_upgrade_date?'Previous: '+new Date(client.previous_upgrade_date).toLocaleDateString('en-ZA',{dateStyle:'medium'}):'Previous date missing' %> · <%= client.contract_term_months||24 %> months</small></div><div><span>Birthday</span><strong><%= client.birthday?new Date(client.birthday).toLocaleDateString('en-ZA',{dateStyle:'medium'}):'Unknown' %></strong><small><%= client.id_number||'ID not captured' %></small></div><div><span>Contact number</span><strong><%= client.cell_number||'Unknown' %></strong><small>Selected line</small></div><div><span>Email</span><strong><%= client.email||'Unknown' %></strong></div><div><span>Town</span><strong><%= client.city_town&&client.city_town!=='null'?client.city_town:'Unknown' %></strong></div><div><span>Handset</span><strong><%= client.handset||'Unknown' %></strong><small><%= client.package_name||'Package unknown' %></small></div><div><span>Account lines</span><strong><%= lines.length %></strong><small><%= lines.filter(x=>x.line_status==='cancelled').length %> cancelled</small></div></section>
<% if(assigned){ %><div class="success-box">Client assignment updated successfully.</div><% } %>
<% if(claimRequested){ %><div class="success-box"><%= claimRequested==='existing'?'A claim request is already waiting for approval.':'Your claim request was sent to the owner and manager for approval.' %></div><% } %>
<% if(changeRequested){ %><div class="success-box">Your <%= changeRequested==='fixed'?'fixed service':'mobile line' %> request was sent to the owner and manager for approval.</div><% } %>
<section class="panel assignment-control"><div><div class="eyebrow">Client ownership</div><h2>Assigned Staff Member</h2><p><%= client.account_number?'This assignment applies to every mobile line on account '+client.account_number+'.':'This client has no account number, so the assignment applies to this client record.' %></p></div><% if(['owner','manager'].includes(currentUser.role)){ %><form method="post" action="<%= basePath %>/backoffice/clients/<%= client.id %>/assign"><input type="hidden" name="return_to" value="customer360"><select name="assigned_staff_id"><option value="">Unassigned</option><% assignmentStaff.forEach(s=>{ %><option value="<%= s.id %>" <%= Number(assignment?.id)===Number(s.id)?'selected':'' %>><%= s.full_name %> — <%= s.role %></option><% }) %></select><button class="btn primary" type="submit">Update Assignment</button></form><% } else { %><strong><%= assignment?.full_name||'Unassigned' %></strong><small>Only an owner or manager can change this assignment.</small><% } %></section>
<section class="authority-card <%= client.account_authority_status==='confirmed'?'confirmed':'warning' %>"><div><span>Authorised Account Contact</span><h2><%= client.main_contact_name&&String(client.main_contact_name).toLowerCase()!=='null'?client.main_contact_name:'Not confirmed' %></h2><p><%= client.main_contact_number&&String(client.main_contact_number).toLowerCase()!=='null'?client.main_contact_number:'No authorised contact number' %></p></div><div><span>Authority</span><strong><%= client.account_authority_status==='confirmed'?'Confirmed':client.account_authority_status==='not_authorised'?'Not authorised':'Verification required' %></strong><a href="<%= basePath %>/customers/<%= client.id %>/propose-change">Request authority update</a></div></section>
<section class="panel"><h2>Account Lines</h2><div class="table-wrap"><table class="data-table"><thead><tr><th>Line</th><th>User / Client</th><th>Package</th><th>Handset</th><th>Previous upgrade</th><th>Next upgrade</th><th>Status</th><th></th></tr></thead><tbody><% lines.forEach(x=>{ %><tr class="<%= x.id===client.id?'selected-line':'' %>"><td><strong><%= x.cell_number||'Unknown' %></strong></td><td><%= x.client_name %></td><td><%= x.package_name||'—' %></td><td><%= x.handset||'—' %></td><td><%= x.previous_upgrade_date?new Date(x.previous_upgrade_date).toLocaleDateString('en-ZA'):'—' %></td><td><strong><%= x.next_upgrade_date?new Date(x.next_upgrade_date).toLocaleDateString('en-ZA'):'—' %></strong></td><td><span class="status-pill <%= x.line_status %>"><%= x.line_status %></span></td><td><a href="<%= basePath %>/customers/<%= x.id %>/360">Open</a></td></tr><% }) %></tbody></table></div></section>
<% if(fixedAccounts&&fixedAccounts.length){ %><section class="panel"><div class="panel-heading-row"><div><div class="eyebrow">Same customer</div><h2>Fixed Services</h2></div><a class="btn primary" href="<%= basePath %>/fixed/accounts/<%= fixedAccounts[0].id %>">Open Fixed Customer 360</a></div><% fixedAccounts.forEach(a=>{ %><a class="mini-client" href="<%= basePath %>/fixed/accounts/<%= a.id %>"><div><strong><%= a.customer_name %></strong><small>Account <%= a.account_number %> · <%= a.fixed_service_count %> fixed service(s)</small></div><span class="search-type fixed">FIXED</span></a><% }) %></section><% } %>
<section class="command-grid"><div class="panel"><h2>Interaction History</h2><% history.forEach(i=>{ %><a class="timeline-item" href="<%= basePath %>/dashboard/inquiries/<%= i.id %>"><time><%= new Date(i.created_at).toLocaleString('en-ZA') %></time><strong><%= i.category_name||'Inquiry' %> · <%= i.status %></strong><p><%= i.query_text||'No inquiry detail' %></p><small><%= i.responsible_name %></small></a><% }) %><% if(!history.length){ %><div class="empty-state">No CRM interactions recorded for this account yet.</div><% } %></div><div class="panel"><h2>Related Tasks</h2><% tasks.forEach(t=>{ %><a class="timeline-item" href="<%= basePath %>/tasks/<%= t.id %>"><time><%= new Date(t.created_at).toLocaleString('en-ZA') %></time><strong><%= t.title %></strong><p><%= t.message %></p><small><%= t.assigned_name %> · <%= t.status %></small></a><% }) %><% if(!tasks.length){ %><div class="empty-state">No related tasks.</div><% } %></div></section>
