<section class="page-head"><div><div class="eyebrow">Owner only</div><h1>Audit History</h1><p>Immutable record of protected actions and approvals.</p></div></section><section class="panel table-card"><table class="data-table"><thead><tr><th>Date</th><th>User</th><th>Action</th><th>Record</th><th>Description</th></tr></thead><tbody><% rows.forEach(r=>{ %><tr><td><%= new Date(r.created_at).toLocaleString('en-ZA') %></td><td><%= r.full_name||'System' %></td><td><strong><%= r.action_type.replaceAll('_',' ') %></strong></td><td><%= r.entity_type||'—' %> <%= r.entity_id||'' %></td><td><%= r.description %></td></tr><% }) %><% if(!rows.length){ %><tr><td colspan="5">No audited events yet.</td></tr><% } %></tbody></table></section>
