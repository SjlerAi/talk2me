<section class="page-head"><div><div class="eyebrow">Fixed business</div><h1>Fixed Accounts</h1><p>One customer account may contain many fixed installations or sites.</p></div><a class="btn primary" href="<%= basePath %>/fixed/services">View Fixed Services</a></section>
<form class="panel report-filters" method="get"><label>Search<input name="q" value="<%= filters.q %>" placeholder="Account, customer, contact, branch or solution ID"></label><label>Status<select name="status"><% ['all','active','inactive','cancelled','unknown'].forEach(x=>{ %><option value="<%= x %>" <%= filters.status===x?'selected':'' %>><%= x %></option><% }) %></select></label><button class="btn primary">Search</button></form>
<section class="panel"><div class="table-wrap"><table class="data-table"><thead><tr><th>Customer</th><th>Account</th><th>Contact</th><th>Fixed services</th><th>Mobile lines</th><th>Assigned</th><th>Status</th><th></th></tr></thead><tbody><% accounts.forEach(a=>{ %><tr><td><strong><%= a.customer_name %></strong></td><td><%= a.account_number %></td><td><%= a.contact_number||'Not captured' %><br><small><%= a.email||'' %></small></td><td><%= a.service_count %> (<%= a.active_service_count||0 %> active)</td><td><%= a.mobile_line_count||0 %></td><td><%= a.assigned_staff_name||'Unassigned' %></td><td><span class="status-pill <%= a.account_status %>"><%= a.account_status %></span></td><td><a class="btn" href="<%= basePath %>/fixed/accounts/<%= a.id %>">Open</a></td></tr><% }) %></tbody></table></div><% if(!accounts.length){ %><div class="empty-state">No fixed accounts match the filters.</div><% } %></section>
