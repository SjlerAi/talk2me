<% const formValues = typeof values !== 'undefined' && values ? values : {}; %>
<section class="page-head"><div><div class="eyebrow">Provisional fixed service</div><h1>Add Fixed Service Now</h1><p>Capture the service now. Management will assign the official account number afterward.</p></div><a class="btn" href="<%= basePath %>/customers/<%= client.id %>/360<%= panelMode?'?panel=1':'' %>">Back</a></section>
<% if (error) { %><div class="error-box"><strong>Fixed service not saved</strong><p><%= error %></p></div><% } %>
<form class="panel form-grid" method="post" action="<%= basePath %>/customers/<%= client.id %>/request-provisional-fixed-service">
  <% if(panelMode){ %><input type="hidden" name="panel" value="1"><% } %>
  <div><label>Account status</label><input value="Pending manager allocation" readonly></div>
  <div><label>Customer</label><input value="<%= client.client_name||'' %>" readonly></div>
  <div><label>Branch / site</label><input name="branch_name" value="<%= formValues.branch_name||'' %>"></div>
  <div><label>Solution ID</label><input name="solution_id" value="<%= formValues.solution_id||'' %>"></div>
  <div><label>Order number</label><input name="order_number" value="<%= formValues.order_number||'' %>"></div>
  <div><label>Router model</label><input name="router_model" value="<%= formValues.router_model||'' %>"></div>
  <div><label>MAC address</label><input name="mac_address" value="<%= formValues.mac_address||'' %>"></div>
  <div><label>Technical SIM number</label><input name="sim_number" value="<%= formValues.sim_number||'' %>"></div>
  <div><label>Package</label><input name="package_name" value="<%= formValues.package_name||'' %>"></div>
  <div><label>Activation date</label><input type="date" name="activation_date" value="<%= formValues.activation_date||'' %>"></div>
  <div><label>Service status</label><select name="service_status"><option value="pending" <%= (formValues.service_status||'pending')==='pending'?'selected':'' %>>Pending</option><option value="active" <%= formValues.service_status==='active'?'selected':'' %>>Active</option><option value="unknown" <%= formValues.service_status==='unknown'?'selected':'' %>>Unknown</option></select></div>
  <div class="full"><label>Installation address</label><input name="installation_address" value="<%= formValues.installation_address||'' %>"></div>
  <div class="full"><label>Technical notes</label><textarea name="technical_notes" rows="4"><%= formValues.technical_notes||'' %></textarea></div>
  <div class="full"><div class="notice warning"><strong>Pending account number</strong><p>The fixed-service request will be saved immediately and sent to management for account allocation.</p><p>Enter at least a branch/site name or installation address.</p></div></div>
  <div class="full"><button class="btn primary" type="submit">Save Fixed Service and Request Account Number</button></div>
</form>