<section class="customer-head"><div><a href="<%= basePath %>/fixed/accounts">← Fixed Accounts</a><div class="eyebrow">Fixed Customer 360</div><h1><%= account.customer_name %></h1><p>Account <%= account.account_number %> · <%= services.length %> fixed service(s) · Assigned to <%= account.assigned_staff_name||'Unassigned' %></p></div><div class="hero-actions account-action-row"><a class="btn primary" href="<%= basePath %>/queries/new?fixed_account_id=<%= account.id %>">New Fixed Inquiry</a><a class="btn opportunity" href="<%= basePath %>/fixed/accounts/<%= account.id %>/request-mobile-line">Add Mobile Line</a><a class="btn opportunity" href="<%= basePath %><%= currentUser.role==='staff'?'/fixed/services/request-new':'/fixed/services/new' %>?account_number=<%= encodeURIComponent(account.account_number) %>">Add Fixed Service</a><a class="btn" href="<%= basePath %>/tasks/new?fixed_account_id=<%= account.id %>">New Task</a><% if(['owner','manager','admin'].includes(currentUser.role)){ %><a class="btn" href="<%= basePath %>/fixed/accounts/<%= account.id %>/edit">Edit Account</a><% } %></div></section>
<section class="answer-grid"><div><span>Contact number</span><strong><%= account.contact_number||'Not captured' %></strong></div><div><span>Email</span><strong><%= account.email||'Not captured' %></strong></div><div><span>Fixed services</span><strong><%= services.length %></strong><small><%= services.filter(x=>x.service_status==='active').length %> active</small></div><div><span>Mobile lines</span><strong><%= mobileLines.length %></strong><small><%= account.linked_mobile_account_number?'Linked by '+account.linked_mobile_account_number:'No mobile link' %></small></div><div><span>Authorised contact</span><strong><%= account.authorised_contact_name||'Not confirmed' %></strong><small><%= account.authorised_contact_number||'' %></small></div><div><span>Authority</span><strong><%= account.authority_status %></strong></div></section>
<% if(serviceSaved){ %><div class="success-box">Fixed service updated successfully.</div><% } %><% if(changeRequested){ %><div class="success-box"><%= changeRequested==='mobile'?'The mobile-line request was sent for manager approval.':'The fixed-service change was sent for manager approval.' %></div><% } %>
<section class="panel"><h2>Fixed Services / Sites</h2><div class="table-wrap"><table class="data-table"><thead><tr><th>Branch</th><th>Solution ID</th><th>Order</th><th>Router</th><th>MAC</th><th>SIM</th><th>Package</th><th>Activated</th><th>Status</th><th class="service-action-cell">Action</th></tr></thead><tbody><% services.forEach(s=>{ %><tr id="service-<%= s.id %>"><td><strong><%= s.branch_name||'—' %></strong></td><td><%= s.solution_id||'—' %></td><td><%= s.order_number||'—' %></td><td><%= s.router_model||'—' %></td><td><%= s.mac_address||'—' %></td><td><%= s.sim_number||'Missing' %></td><td><%= s.package_name||'—' %></td><td><%= s.activation_date?new Date(s.activation_date).toLocaleDateString('en-ZA'):'Missing' %></td><td><span class="status-pill <%= s.service_status %>"><%= s.service_status %></span><% if(s.data_quality_notes){ %><small class="danger-text"><%= s.data_quality_notes %></small><% } %></td><td class="service-action-cell"><a class="btn" href="<%= basePath %>/fixed/services/<%= s.id %>/edit"><%= currentUser.role==='staff'?'Request Change':'Edit Service' %></a></td></tr><% }) %></tbody></table></div></section>
<% if(mobileLines.length){ %><section class="panel"><h2>Linked Mobile Lines</h2><div class="table-wrap"><table class="data-table"><thead><tr><th>Client</th><th>Cellphone</th><th>Package</th><th>Handset</th><th>Upgrade</th><th class="line-action-cell">Action</th></tr></thead><tbody><% mobileLines.forEach(x=>{ %><tr><td><%= x.client_name %></td><td><%= x.cell_number||'—' %></td><td><%= x.package_name||'—' %></td><td><%= x.handset||'—' %></td><td><%= x.next_upgrade_date?new Date(x.next_upgrade_date).toLocaleDateString('en-ZA'):'—' %></td><td class="line-action-cell"><a class="btn" href="<%= basePath %><%= currentUser.role==='staff'?'/customers/'+x.id+'/propose-change':'/backoffice/clients/'+x.id+'/edit' %>"><%= currentUser.role==='staff'?'Request Line Change':'Edit Line' %></a><a class="open-line-link" href="<%= basePath %>/customers/<%= x.id %>/360">Open Line</a></td></tr><% }) %></tbody></table></div></section><% } %>
<section class="command-grid"><div class="panel"><h2>Fixed Inquiry History</h2><% inquiries.forEach(i=>{ %><a class="timeline-item" href="<%= basePath %>/dashboard/inquiries/<%= i.id %>"><time><%= new Date(i.created_at).toLocaleString('en-ZA') %></time><strong><%= i.category_name||'Inquiry' %> · <%= i.status %></strong><p><%= i.query_text||'No detail' %></p><small><%= i.staff_name %></small></a><% }) %><% if(!inquiries.length){ %><div class="empty-state">No fixed inquiries recorded yet.</div><% } %></div><div class="panel"><h2>Related Tasks</h2><% tasks.forEach(t=>{ %><a class="timeline-item" href="<%= basePath %>/tasks/<%= t.id %>"><time><%= new Date(t.created_at).toLocaleString('en-ZA') %></time><strong><%= t.title %></strong><p><%= t.message %></p><small><%= t.assigned_name %> · <%= t.status %></small></a><% }) %><% if(!tasks.length){ %><div class="empty-state">No fixed-service tasks.</div><% } %></div></section>
