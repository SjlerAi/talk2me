<% const managerView = canApprove ? 'approval' : (archived ? 'archive' : 'active'); %>
<% const managerUrl = `${basePath}/tasks?view=${managerView}${panelMode?'&panel=1':''}`; %>
<section class="hero-row task-work-detail-hero">
  <div>
    <a class="task-manager-back" href="<%= managerUrl %>">← Back to Tasks & Messages</a>
    <h1><%= task.type==='notification'?'Message':'Task' %> #<%= task.id %></h1>
    <p>Assigned to <strong><%= task.assigned_name %></strong> by <%= task.created_by_name %>.</p>
  </div>
  <div class="task-work-detail-badges"><span class="badge <%= task.priority %>"><%= task.priority %></span><span class="workflow-state"><%= task.workflow_label %></span></div>
</section>
<% if(waitingApproval){ %><div class="alert warning task-approval-alert"><strong>Completed — sender acknowledgement required.</strong><span>This item remains active until the sender accepts it or returns it for more work.</span></div><% } %>
<% if(task.workflow_state==='returned'&&task.return_reason){ %><div class="alert error"><strong>Returned for more work</strong> — <%= task.return_reason %></div><% } %>
<section class="grid two task-work-detail-grid">
  <div class="panel"><h2><%= task.title %></h2><p class="task-message"><%= task.message %></p><dl class="detail-list"><dt>Type</dt><dd><%= task.type==='notification'?'Message':'Task' %></dd><dt>Due</dt><dd><%= task.due_at?new Date(task.due_at).toLocaleString('en-ZA'):'No fixed deadline' %></dd><dt>Created</dt><dd><%= new Date(task.created_at).toLocaleString('en-ZA') %></dd><dt>Seen</dt><dd><%= task.seen_at?new Date(task.seen_at).toLocaleString('en-ZA'):'Not yet opened' %></dd><dt>Started</dt><dd><%= task.started_at?new Date(task.started_at).toLocaleString('en-ZA'):'Not started' %></dd><% if(task.completion_note){ %><dt>Completion note</dt><dd><%= task.completion_note %></dd><% } %><% if(task.related_client_name){ %><dt>Customer</dt><dd><%= task.related_client_name %></dd><% } %></dl>
    <% if(isAssignee&&!archived&&!waitingApproval){ %><form method="post" action="<%= basePath %>/tasks/<%= task.id %>/my-priority<%= panelMode?'?panel=1':'' %>" class="task-priority-toggle"><input type="hidden" name="return_view" value="active"><% if(panelMode){ %><input type="hidden" name="panel" value="1"><% } %><input type="hidden" name="enabled" value="<%= priorityToday?'0':'1' %>"><button class="btn <%= priorityToday?'':'primary' %>" type="submit"><%= priorityToday?'Remove from My Priority':'Make My Priority Today' %></button></form><% } %>
  </div>
  <div class="panel task-work-actions"><h2>Action</h2>
    <% if(canApprove){ %><p>The recipient says this work is complete. Review the completion note and choose one action.</p><form method="post" action="<%= basePath %>/tasks/<%= task.id %>/accept<%= panelMode?'?panel=1':'' %>"><input type="hidden" name="return_view" value="approval"><% if(panelMode){ %><input type="hidden" name="panel" value="1"><% } %><button class="btn primary" type="submit">Accept & Archive</button></form><form method="post" action="<%= basePath %>/tasks/<%= task.id %>/return<%= panelMode?'?panel=1':'' %>" class="task-return-form"><input type="hidden" name="return_view" value="approval"><% if(panelMode){ %><input type="hidden" name="panel" value="1"><% } %><label>Reason for returning<textarea name="reason" rows="4" required placeholder="Explain what still needs to be done"></textarea></label><button class="btn danger" type="submit">Return for More Work</button></form>
    <% } else if(canUpdate){ %><form method="post" action="<%= basePath %>/tasks/<%= task.id %>/status<%= panelMode?'?panel=1':'' %>"><input type="hidden" name="return_view" value="active"><% if(panelMode){ %><input type="hidden" name="panel" value="1"><% } %><label>Status<select name="status"><option value="seen" <%= task.status==='seen'?'selected':'' %>>Open / Seen</option><option value="in_progress" <%= task.status==='in_progress'?'selected':'' %>>In progress</option><option value="completed"><%= task.type==='notification'?'Acknowledge message':'Complete task' %></option><% if(management){ %><option value="cancelled">Cancelled</option><% } %></select></label><label><%= task.type==='notification'?'Acknowledgement note':'Completion note' %><textarea name="completion_note" rows="4" <%= task.type==='task'?'required':'' %> placeholder="<%= task.type==='task'?'Explain what was completed':'Optional note' %>"><%= task.completion_note||'' %></textarea></label><button class="btn primary" type="submit">Update & Return to Task Manager</button></form>
    <% } else if(archived){ %><p>This item has been accepted and is safely stored in the archive.</p><a class="btn" href="<%= basePath %>/tasks?view=archive<%= panelMode?'&panel=1':'' %>">Open Archive</a>
    <% } else if(waitingApproval){ %><p>Waiting for <strong><%= task.created_by_name %></strong> to accept the completed work or return it.</p><a class="btn" href="<%= managerUrl %>">Back to Tasks & Messages</a>
    <% } else { %><p>You can follow the progress and add an update below. The assigned staff member controls the work status.</p><a class="btn" href="<%= managerUrl %>">Back to Tasks & Messages</a><% } %>
  </div>
</section>
<section class="panel"><h2>History and Updates</h2><% if(!archived){ %><form method="post" action="<%= basePath %>/tasks/<%= task.id %>/comments<%= panelMode?'?panel=1':'' %>" class="inline-comment"><input type="hidden" name="return_view" value="<%= managerView %>"><% if(panelMode){ %><input type="hidden" name="panel" value="1"><% } %><textarea name="comment" rows="3" placeholder="Add a progress note or reply..."></textarea><button class="btn">Add Update & Return</button></form><% } %><div class="task-history"><% comments.forEach(c=>{ %><article class="comment"><strong><%= c.full_name %></strong><small><%= new Date(c.created_at).toLocaleString('en-ZA') %></small><p><%= c.comment %></p></article><% }) %><% if(!comments.length){ %><p class="muted">No updates recorded yet.</p><% } %></div></section>
