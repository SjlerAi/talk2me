<section class="page-head"><div><div class="eyebrow">Customer intelligence</div><h1>Upgrade Centre</h1><p>Complete upgrade opportunities from the historical customer database.</p></div><a class="btn" href="<%= basePath %>/command-centre">Command Centre</a></section>
<form class="panel centre-filters" method="get"><div><label>Window</label><select name="window"><% [['overdue','Overdue'],['today','Due today'],['week','Next 7 days'],['month','This month'],['future','All future']].forEach(x=>{ %><option value="<%= x[0] %>" <%= filters.window===x[0]?'selected':'' %>><%= x[1] %></option><% }) %></select></div><div><label>Search</label><input name="q" value="<%= filters.q %>" placeholder="Cellphone, account, client or package"></div><button class="btn primary">Run Report</button><a class="btn" href="<%= basePath %>/upgrade-centre.csv?window=<%= encodeURIComponent(filters.window) %>&q=<%= encodeURIComponent(filters.q) %>">Export CSV</a><button type="button" class="btn" onclick="window.print()">Print</button></form>
<section class="panel table-card"><div class="panel-heading-row"><div><h2><%= rows.length %> upgrade line(s)</h2><p class="muted">Previous date + contract term = next upgrade date</p></div></div><table class="data-table"><thead><tr><th>Client / Account</th><th>Cellphone</th><th>Package / Handset</th><th>Previous</th><th>Term</th><th>Next upgrade</th><th>Position</th><th>Staff</th><th>Lines</th><th></th></tr></thead><tbody><% rows.forEach(c=>{ %><tr><td><strong><%= c.client_name %></strong><small><%= c.account_number||'No account' %></small></td><td><%= c.cell_number||'—' %></td><td><%= c.package_name||'—' %><small><%= c.handset||'No handset' %></small></td><td><%= c.previous_upgrade_date?new Date(c.previous_upgrade_date).toLocaleDateString('en-ZA'):'—' %></td><td><%= c.contract_term_months||24 %> months</td><td><strong><%= new Date(c.next_upgrade_date).toLocaleDateString('en-ZA') %></strong></td><td><span class="badge <%= c.days_until<0?'danger':c.days_until===0?'warn':'ok' %>"><%= c.days_until<0?Math.abs(c.days_until)+' days overdue':c.days_until===0?'Due today':'In '+c.days_until+' days' %></span></td><td><%= c.assigned_name %><small>Previous: <%= c.last_upgrade_consultant||'Unknown' %></small></td><td><%= c.line_count||1 %></td><td><a class="btn tiny" href="<%= basePath %>/customers/<%= c.id %>/360">Open</a></td></tr><% }) %><% if(!rows.length){ %><tr><td colspan="10">No upgrade lines match these filters.</td></tr><% } %></tbody></table></section>
