<section class="page-head"><div><div class="eyebrow">My submitted changes</div><h1>My Change Requests</h1><p>Track changes waiting for manager or owner approval.</p></div><a class="btn" href="<%= basePath %>/my-command-centre">My Command Centre</a></section><section class="panel table-card"><table class="data-table"><thead><tr><th>Submitted</th><th>Customer</th><th>Change</th><th>Approval</th><th>Status</th><th>Reviewer</th></tr></thead><tbody><% rows.forEach(r=>{ %><tr><td><%= new Date(r.created_at).toLocaleString('en-ZA') %></td><td><strong><%= r.client_name||r.summary %></strong><small><%= r.cell_number||r.account_number||'' %></small></td><td><%= r.summary %><% if(r.reason){ %><small><%= r.reason %></small><% } %></td><td><%= r.required_approval_role %></td><td><span class="status-pill"><%= r.status.replaceAll('_',' ') %></span></td><td><%= r.reviewed_by_name||'Waiting' %><% if(r.review_comment){ %><small><%= r.review_comment %></small><% } %></td></tr><% }) %><% if(!rows.length){ %><tr><td colspan="6">You have not submitted any customer changes.</td></tr><% } %></tbody></table></section>
