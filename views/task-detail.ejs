<section class="hero-row"><div><h1><%= task.type==='task'?'Task':'Notification' %> #<%= task.id %></h1><p>Assigned to <strong><%= task.assigned_name %></strong> by <%= task.created_by_name %>.</p></div><div><span class="badge <%= task.priority %>"><%= task.priority %></span> <span class="badge <%= task.status %>"><%= task.status %></span></div></section>
<% if(created){ %><div class="alert success">Saved. Email status: <strong><%= task.email_status %></strong><% if(task.email_error){ %> — <%= task.email_error %><% } %></div><% } %>
<section class="grid two"><div class="panel"><h2><%= task.title %></h2><p class="task-message"><%= task.message %></p><dl class="detail-list"><dt>Due</dt><dd><%= task.due_at?new Date(task.due_at).toLocaleString():'Not set' %></dd><dt>Email</dt><dd><%= task.assigned_email %> — <%= task.email_status %></dd><dt>Created</dt><dd><%= new Date(task.created_at).toLocaleString() %></dd><% if(task.related_client_name){ %><dt>Mobile client</dt><dd><%= task.related_client_name %></dd><% } %><% if(task.related_fixed_name){ %><dt>Fixed account</dt><dd><a href="<%= basePath %>/fixed/accounts/<%= task.related_fixed_account_id %><%= panelMode?'?panel=1':'' %>"><%= task.related_fixed_name %> — <%= task.related_fixed_account %></a></dd><% } %></dl></div>
<div class="panel"><h2>Status</h2><% if(canUpdate){ %><form method="post" action="<%= basePath %>/tasks/<%= task.id %>/status<%= panelMode?'?panel=1':'' %>"><% if(panelMode){ %><input type="hidden" name="panel" value="1"><% } %><label>Status<select name="status"><option value="seen" <%= task.status==='seen'?'selected':'' %>>Open / Seen</option><option value="in_progress" <%= task.status==='in_progress'?'selected':'' %>>In progress</option><option value="completed">Completed</option><% if(isOwner){ %><option value="cancelled">Cancelled</option><% } %></select></label><label>Completion note<textarea name="completion_note" rows="4" placeholder="What was completed?"><%= task.completion_note||'' %></textarea></label><button class="btn primary"><%= task.type==='notification'?'Acknowledge / Update':'Update Task' %></button></form><% } else if(canReopen){ %><p>This item is in the completed archive.</p><form method="post" action="<%= basePath %>/tasks/<%= task.id %>/reopen<%= panelMode?'?panel=1':'' %>"><% if(panelMode){ %><input type="hidden" name="panel" value="1"><% } %><button class="btn primary" type="submit" onclick="return confirm('Reopen this item and return it to Active?')">Reopen</button></form><% } else { %><p><%= isArchived?'This completed item is read-only.':'The recipient updates the task status. You can add a note below.' %></p><% } %></div></section>
<section class="panel"><h2>History and Notes</h2><% if(!isArchived){ %><form method="post" action="<%= basePath %>/tasks/<%= task.id %>/comments<%= panelMode?'?panel=1':'' %>" class="inline-comment"><% if(panelMode){ %><input type="hidden" name="panel" value="1"><% } %><textarea name="comment" rows="3" placeholder="Add a progress note..."></textarea><button class="btn">Add Note</button></form><% } %><% comments.forEach(c=>{ %><div class="comment"><strong><%= c.full_name %></strong><small><%= new Date(c.created_at).toLocaleString('en-ZA') %></small><p><%= c.comment %></p></div><% }) %><% if(!comments.length){ %><p class="muted">No updates recorded yet.</p><% } %></section>
