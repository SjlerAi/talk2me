<section class="page-head"><div><div class="eyebrow">Fixed business</div><h1>Fixed Services</h1><p>Every installation, router and branch is kept as its own service.</p></div><a class="btn primary" href="<%= basePath %>/fixed/accounts">View Fixed Accounts</a></section>
<form class="panel report-filters" method="get"><label>Search<input name="q" value="<%= filters.q %>" placeholder="Customer, account, branch, solution, order, SIM or MAC"></label><label>Status<select name="status"><% ['all','active','pending','suspended','cancelled','unknown'].forEach(x=>{ %><option value="<%= x %>" <%= filters.status===x?'selected':'' %>><%= x %></option><% }) %></select></label><button class="btn primary">Search</button></form>
<section class="panel"><div class="table-wrap"><table class="data-table"><thead><tr><th>Customer / account</th><th>Branch</th><th>Solution / order</th><th>Router / MAC</th><th>SIM</th><th>Package</th><th>Activated</th><th>Status</th><th></th></tr></thead><tbody><% services.forEach(s=>{ %><tr><td><strong><%= s.customer_name %></strong><br><small><%= s.account_number %></small></td><td><%= s.branch_name||'—' %></td><td><%= s.solution_id||'—' %><br><small><%= s.order_number||'' %></small></td><td><%= s.router_model||'—' %><br><small><%= s.mac_address||'' %></small></td><td><%= s.sim_number||'Missing' %></td><td><%= s.package_name||'—' %></td><td><%= s.activation_date?new Date(s.activation_date).toLocaleDateString('en-ZA'):'Missing' %></td><td><span class="status-pill <%= s.service_status %>"><%= s.service_status %></span><% if(s.data_quality_notes){ %><small class="danger-text"><%= s.data_quality_notes %></small><% } %></td><td><a class="btn" href="<%= basePath %>/fixed/accounts/<%= s.fixed_account_id %>#service-<%= s.id %>">Open</a></td></tr><% }) %></tbody></table></div></section>
