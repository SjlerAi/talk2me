<section class="page-head"><div><div class="eyebrow">Protected customer data</div><h1>Propose a Change</h1><p>Your request will not change the live database until the required manager or owner approves it.</p></div><a class="btn" href="<%= basePath %>/customers/<%= client.id %>/360">Back to Customer</a></section>
<% if(saved==='1'){ %><div class="success-box">Change submitted for approval.</div><% } else if(saved==='none'){ %><div class="alert">No changed fields were submitted.</div><% } %>
<form class="panel form-card" method="post"><div class="form-grid"><label>Client / Company<input name="client_name" value="<%= client.client_name||'' %>"></label><label>Cellphone<input name="cell_number" value="<%= client.cell_number||'' %>"></label><label>Email<input name="email" value="<%= client.email||'' %>"></label><label>Town<input name="city_town" value="<%= client.city_town&&client.city_town!=='null'?client.city_town:'' %>"></label><label>Package<input name="package_name" value="<%= client.package_name||'' %>"></label><label>Handset<input name="handset" value="<%= client.handset||'' %>"></label><label>Line status<select name="line_status"><% ['unknown','active','inactive','cancelled','suspended'].forEach(x=>{ %><option <%= client.line_status===x?'selected':'' %>><%= x %></option><% }) %></select></label><label>Account number<input name="account_number" value="<%= client.account_number||'' %>"></label><label>ID number<input name="id_number" value="<%= client.id_number||'' %>"></label><label>Previous upgrade<input type="date" name="previous_upgrade_date" value="<%= client.previous_upgrade_date?new Date(client.previous_upgrade_date).toISOString().slice(0,10):'' %>"></label><label>Contract term<select name="contract_term_months"><option value="24" <%= Number(client.contract_term_months)===24?'selected':'' %>>24 months</option><option value="36" <%= Number(client.contract_term_months)===36?'selected':'' %>>36 months</option></select></label><label>Authorised person<input name="main_contact_name" value="<%= client.main_contact_name||'' %>"></label><label>Authorised number<input name="main_contact_number" value="<%= client.main_contact_number||'' %>"></label><label>Authority<select name="account_authority_status"><% ['unknown','confirmed','not_authorised'].forEach(x=>{ %><option <%= client.account_authority_status===x?'selected':'' %>><%= x.replace('_',' ') %></option><% }) %></select></label><label class="full">Reason for change<textarea name="reason" required rows="4"></textarea></label></div><button class="btn primary">Submit for Approval</button></form>
