<section class="page-head"><div><div class="eyebrow">Management report</div><h1>Fixed Services Centre</h1><p>All fixed accounts, installations and data-quality items in one report.</p></div><div class="hero-actions"><a class="btn primary" href="<%= basePath %>/fixed-centre.csv">Export CSV</a><button class="btn" onclick="window.print()">Print</button></div></section>
<section class="command-stats"><a href="<%= basePath %>/fixed/services"><span>Total services</span><strong><%= stats.total_services||0 %></strong></a><a class="opportunity" href="<%= basePath %>/fixed/services?status=active"><span>Active services</span><strong><%= stats.active_services||0 %></strong></a><a href="<%= basePath %>/fixed/accounts"><span>Fixed accounts</span><strong><%= stats.total_accounts||0 %></strong></a><a class="warning" href="<%= basePath %>/fixed/services?q=Missing"><span>Missing activation</span><strong><%= stats.missing_activation||0 %></strong></a><a class="warning" href="<%= basePath %>/fixed/services"><span>Missing SIM</span><strong><%= stats.missing_sim||0 %></strong></a></section>
<section class="command-grid"><div class="panel"><h2>By Account</h2><div class="table-wrap"><table class="data-table"><thead><tr><th>Customer</th><th>Account</th><th>Total</th><th>Active</th><th></th></tr></thead><tbody><% byAccount.forEach(x=>{ %><tr><td><%= x.customer_name %></td><td><%= x.account_number %></td><td><%= x.total %></td><td><%= x.active||0 %></td><td><a href="<%= basePath %>/fixed/accounts/<%= x.id %>">Open</a></td></tr><% }) %></tbody></table></div></div><div class="panel"><h2>By Package</h2><div class="table-wrap"><table class="data-table"><thead><tr><th>Package</th><th>Total</th></tr></thead><tbody><% byPackage.forEach(x=>{ %><tr><td><%= x.package_name||'Unknown' %></td><td><%= x.total %></td></tr><% }) %></tbody></table></div></div></section>
