<section class="page-head"><div><h1>Birthday Corrections</h1><p>Birth dates automatically derived from the first six digits of valid 13-digit South African ID numbers.</p></div><a class="btn" href="<%= basePath %>/backoffice">Back Office</a></section>
<div class="card"><div style="margin-bottom:16px"><a class="btn" href="<%= basePath %>/backoffice/reports/new-contacts">Walk-in Report</a></div><div class="table-wrap"><table><thead><tr><th>Corrected</th><th>Client</th><th>Contact</th><th>ID number</th><th>Previous birthday</th><th>Birthday from ID</th><th>Action</th></tr></thead><tbody><% if(!(rows||[]).length){ %><tr><td colspan="7">No birthday corrections recorded yet.</td></tr><% } %><% (rows||[]).forEach(r=>{ %><tr><td><%= new Date(r.corrected_at).toLocaleString('en-ZA') %></td><td><strong><%= r.client_name %></strong></td><td><%= r.cell_number||'—' %></td><td><%= r.id_number||'—' %></td><td><%= r.previous_birthday ? new Date(r.previous_birthday).toISOString().slice(0,10) : 'Blank' %></td><td><%= r.derived_birthday ? new Date(r.derived_birthday).toISOString().slice(0,10) : '—' %></td><td><a class="btn tiny" href="<%= basePath %>/backoffice/clients/<%= r.client_id %>/edit">Open client</a></td></tr><% }) %></tbody></table></div></div>