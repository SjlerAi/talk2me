<section class="page-head"><div><h1>New Walk-in Contacts</h1><p>Management report for potential clients captured from walk-ins or enquiries.</p></div><div><a class="btn" href="<%= basePath %>/backoffice/clients?view=prospects">Manage Prospects</a> <a class="btn" href="<%= basePath %>/backoffice">Back Office</a></div></section>
<div class="card form-card"><form method="get" class="report-filters"><div><label>From</label><input type="date" name="from" value="<%= filters.from %>"></div><div><label>To</label><input type="date" name="to" value="<%= filters.to %>"></div><div><label>Captured by</label><select name="staff_id"><option value="">All staff</option><% staff.forEach(s=>{ %><option value="<%= s.id %>" <%= Number(filters.staff_id)===Number(s.id)?'selected':'' %>><%= s.full_name %></option><% }) %></select></div><button class="btn primary" type="submit">Run Report</button></form></div>
<div class="stats-grid report-stats"><div class="stat-card"><span>Total new contacts</span><strong><%= totals.total||0 %></strong></div><div class="stat-card"><span>New</span><strong><%= totals.new_count||0 %></strong></div><div class="stat-card"><span>Contacted</span><strong><%= totals.contacted_count||0 %></strong></div><div class="stat-card"><span>Qualified</span><strong><%= totals.qualified_count||0 %></strong></div><div class="stat-card"><span>Converted</span><strong><%= totals.converted_count||0 %></strong></div></div>
<div class="card table-card"><h2>By staff member</h2><table class="data-table"><thead><tr><th>Staff</th><th>Total</th><th>New</th><th>Contacted</th><th>Qualified</th><th>Converted</th></tr></thead><tbody><% if(!summary.length){ %><tr><td colspan="6">No new walk-in contacts in this period.</td></tr><% } %><% summary.forEach(r=>{ %><tr><td><strong><%= r.staff_name %></strong></td><td><%= r.total %></td><td><%= r.new_count %></td><td><%= r.contacted_count %></td><td><%= r.qualified_count %></td><td><%= r.converted_count %></td></tr><% }) %></tbody></table></div>
<div class="card table-card"><h2>Contact detail</h2><table class="data-table"><thead><tr><th>Date</th><th>Potential client</th><th>Contact</th><th>Inquiry</th><th>Action taken</th><th>Captured by</th><th>Assigned staff</th><th>Status</th><th>Action</th></tr></thead><tbody><% if(!rows.length){ %><tr><td colspan="9">No records found.</td></tr><% } %><% rows.forEach(r=>{ %><tr>
<td><%= new Date(r.created_at).toLocaleString('en-ZA') %></td>
<td><strong><%= r.client_name %></strong><br><small><%= r.email||'' %></small></td>
<td><%= r.cell_number||'—' %></td>
<td><% if(r.inquiry_category){ %><strong><%= r.inquiry_category %></strong><br><% } %><%= r.query_text||'No inquiry detail captured' %></td>
<td><%= r.action_taken||r.result_found||'Not captured yet' %></td>
<td><%= r.created_by_name||'Unknown' %></td>
<td><%= r.assigned_staff_name||r.created_by_name||'Unassigned' %></td>
<td><span class="client-status <%= r.lead_status||'new' %>"><%= (r.lead_status||'new').replace('_',' ') %></span></td>
<td><div class="report-actions"><a class="btn tiny" href="<%= basePath %>/backoffice/clients/<%= r.id %>/edit">Edit / Add details</a><% if(currentUser.role==='owner'){ %><form method="post" action="<%= basePath %>/backoffice/clients/<%= r.id %>/delete" onsubmit="return confirm('Archive this potential client? The record will be hidden but kept for audit history.');"><input type="hidden" name="return_to" value="/backoffice/reports/new-contacts?from=<%= encodeURIComponent(filters.from) %>&to=<%= encodeURIComponent(filters.to) %><%= filters.staff_id ? '&staff_id='+encodeURIComponent(filters.staff_id) : '' %>"><button class="btn tiny danger" type="submit">Archive</button></form><% } %></div></td>
</tr><% }) %></tbody></table></div>
