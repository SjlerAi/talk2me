{
  "name": "talk2me-crm",
  "version": "6.0.0-alpha.2",
  "description": "Talk2Me OS v6 alpha 2 - branded workstation with left navigation and daily desk widgets",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "check": "node --check server.js && node --check src/routes/os.js && node --check public/js/os-v6.js",
    "digest:staff-work": "node scripts/send-staff-work-digest.js",
    "digest:owner": "node scripts/send-owner-daily-brief.js",
    "digest:staff-clients": "node scripts/send-staff-client-digest.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.4.5",
    "ejs": "^3.1.10",
    "express": "^4.19.2",
    "express-ejs-layouts": "^2.5.1",
    "express-session": "^1.18.0",
    "mysql2": "^3.11.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.15"
  },
  "devDependencies": {
    "nodemon": "^3.1.4"
  }
}
